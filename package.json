{
  "name": "image-asset-manager",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "clean": "rm -rf .next",
    "clean:dev": "rm -rf .next/dev .next/cache",
    "clean:build": "rm -rf .next/build .next/server .next/static .next/types .next/diagnostics",
    "dev": "npm run clean:dev && next dev",
    "dev:fast": "next dev",
    "build": "npm run clean:build && next build",
    "start": "next start",
    "lint": "eslint .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.2.5",
    "@vercel/postgres": "^0.9.0",
    "@vercel/sdk": "^1.19.40",
    "better-auth": "^1.6.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "eslint-config-next": "^16.2.4",
    "jotai": "^2.19.0",
    "jotai-family": "^1.0.1",
    "next": "^16.2.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-photo-view": "^1.2.7",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0"
  }
}
